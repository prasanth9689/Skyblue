<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

    <RelativeLayout
        android:layout_width="387dp"
        android:layout_height="56dp">

        <ImageView
            android:id="@+id/id_company_picture_image_view"
            android:layout_width="78dp"
            android:layout_height="64dp"
            tools:srcCompat="@tools:sample/avatars" />

        <TextView
            android:id="@+id/id_company_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="90dp"
            android:hint="Company Name"
            android:textColor="@color/company_search_light_dark"

            android:textSize="18sp" />
        <TextView
            android:id="@+id/id_company_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="90dp"
            android:hint="Company id"
            android:textSize="18sp"
            android:visibility="invisible"/>



        <TextView
            android:id="@+id/id_company_picture_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_video_url"
            android:layout_marginLeft="90dp"
            android:text="company picture url"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/id_company_country"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_image_url"
            android:layout_marginLeft="90dp"
            android:text="company country"
            android:textColor="@color/company_search_light_dark"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/id_company_field"
            android:layout_width="168dp"
            android:layout_height="29dp"
            android:layout_marginLeft="89dp"
            android:layout_marginTop="30dp"
            android:hint="Field"
            android:visibility="visible" />




    </RelativeLayout>

</LinearLayout>