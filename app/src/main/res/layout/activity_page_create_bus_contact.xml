<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".channel.PageCreateEduContactActivity">

    <RelativeLayout
        android:id="@+id/top_nav"
        android:layout_width="match_parent"
        android:layout_height="50dp">


        <ImageView
            android:id="@+id/id_back"
            android:layout_width="35dp"
            android:layout_height="30dp"
            app:srcCompat="@drawable/common_arrow_back"
            android:layout_centerVertical="true"
            android:layout_marginLeft="5dp"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginLeft="5dp"
            android:layout_toRightOf="@id/id_back"
            android:text="Contact information"
            android:textColor="#000000"
            android:textSize="20dp" />
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_marginTop="51dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/main_activity_root_view">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            >



            <TextView
                android:id="@+id/text_enter_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:text="Enter phone"/>

            <EditText
                android:id="@+id/id_phone"
                style="@style/Widget.MaterialComponents.AutoCompleteTextView.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/text_enter_phone"
                android:layout_centerHorizontal="true"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/common_border_light_black_radius"
                android:ems="10"
                android:hint="Phone"
                android:imeOptions="normal"
                android:inputType="phone"
                android:singleLine="false"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                tools:layout_editor_absoluteX="98dp"
                tools:layout_editor_absoluteY="123dp" />

            <TextView
                android:id="@+id/text_website"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:text="Enter website address"
                android:layout_below="@id/id_phone"/>

            <EditText
                android:id="@+id/id_website"
                style="@style/Widget.MaterialComponents.AutoCompleteTextView.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/text_website"
                android:layout_centerHorizontal="true"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/common_border_light_black_radius"
                android:ems="10"
                android:hint="https://"
                android:imeOptions="normal"
                android:inputType="text"
                android:singleLine="false"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                tools:layout_editor_absoluteX="98dp"
                tools:layout_editor_absoluteY="123dp" />


            <Button
                android:id="@+id/id_next_button"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_below="@+id/id_website"
                android:layout_centerHorizontal="true"

                android:layout_marginTop="10dp"
                android:background="@color/colorPrimaryDark"

                android:text="NEXT"
                android:textColor="#FFFFFF"
                tools:layout_editor_absoluteX="161dp"
                tools:layout_editor_absoluteY="234dp" />
        </RelativeLayout>


    </androidx.cardview.widget.CardView>

</RelativeLayout>