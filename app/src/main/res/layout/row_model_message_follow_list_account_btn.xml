<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:descendantFocusability="beforeDescendants">


    <RelativeLayout

        android:id="@+id/relMessageContainer"
        android:layout_width="match_parent"
        android:layout_height="53dp"
        android:layout_marginTop="5dp"
        android:descendantFocusability="afterDescendants">

        <ImageView
            android:id="@+id/id_user_rounded_thumbnail_notification"
            android:layout_width="47dp"
            android:layout_height="49dp"

            android:layout_centerHorizontal="false"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/placeholder_person" />

        <TextView
            android:id="@+id/id_model_notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="0dp"
            android:padding="5dp"
            android:text="Id"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#000000"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/sender_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="name"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#3A3838"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/following_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/sender_name"
            android:layout_marginLeft="50dp"

            android:layout_marginBottom="-10dp"
            android:padding="5dp"
            android:text="following id"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#F30000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/status_model_notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/sender_id"
            android:layout_marginLeft="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="status"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#3A3838"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/profile_url_model_notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/status_model_notification"
            android:layout_marginLeft="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="profile_url"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#3A3838"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/sender_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/sender_name"
            android:layout_marginLeft="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="sender_id"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#3A3838"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />


    </RelativeLayout>


</FrameLayout>
