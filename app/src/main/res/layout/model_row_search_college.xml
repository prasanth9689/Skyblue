<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

    <RelativeLayout
        android:layout_width="387dp"
        android:layout_height="56dp">

        <ImageView
            android:id="@+id/id_college_picture_image_view"
            android:layout_width="78dp"
            android:layout_height="64dp"
            tools:srcCompat="@tools:sample/avatars" />

        <TextView
            android:id="@+id/id_college_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="90dp"
            android:layout_marginRight="5dp"
            android:hint="college name"

            android:textColor="@color/company_search_light_dark"
            android:textSize="18sp" />
        <TextView
            android:id="@+id/id_college_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="90dp"
            android:hint="College id"
            android:textSize="18sp"
            android:visibility="invisible"/>



        <TextView
            android:id="@+id/id_college_picture_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_video_url"
            android:layout_marginLeft="90dp"
            android:text="College picture url"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/id_college_country"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_image_url"
            android:layout_marginLeft="90dp"
            android:text="College country"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/id_college_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/text_image_url"
            android:layout_marginLeft="90dp"
            android:text="College state"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/id_college_category"
            android:layout_width="168dp"
            android:layout_height="29dp"
            android:layout_marginLeft="89dp"
            android:layout_marginTop="30dp"
            android:hint="College category"
            android:visibility="invisible"
            tools:visibility="invisible" />




    </RelativeLayout>

</LinearLayout>