    <RelativeLayout
        android:id="@+id/vm_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/edit_text_full_color_blue">

        <Button
            android:id="@+id/f_lbl"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:background="@drawable/fb_f"
            android:text="F"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/vm_lbl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/f_lbl"
            android:background="@drawable/flag_transparent"
            android:gravity="center_vertical"
            android:paddingLeft="10dp"
            android:text="VIRTUALMAZE"
            android:textColor="@color/white" />

    </RelativeLayout>

    <RelativeLayout
        android:layout_below="@+id/vm_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/edit_text_full_color_blue">
        <Button
            android:id="@+id/f_lbl1"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:background="@drawable/fb_f"
            android:text="F"
            />

        <Button
            android:id="@+id/vm_lbl1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/f_lbl1"
            android:background="@drawable/flag_transparent"
            android:gravity="center_vertical"
            android:paddingLeft="10dp"
            android:text="OFFLINE MAP NAVIGATION"
            android:textColor="@color/white" />



    </RelativeLayout>



