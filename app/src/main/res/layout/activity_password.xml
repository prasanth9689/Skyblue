<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    tools:context=".registration.PasswordActivity">

<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <TextView
        android:id="@+id/textView_set_pass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:fontFamily="@font/open_sans"
        android:text="@string/set_password"
        android:textAppearance="@style/Base.TextAppearance.AppCompat.Large"
        android:textColor="@color/colorMessageBackground"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editTextPass1"
        style="@style/Widget.MaterialComponents.AutoCompleteTextView.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/textView_set_pass"
        android:fontFamily="@font/open_sans"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="20dp"
        android:layout_weight="2"
        android:background="@drawable/edit_text_border_color_light_blue"
        android:hint="@string/enter_password"
        android:inputType="textPassword"
        android:maxLength="10"
        android:textAppearance="@style/TextAppearance.AppCompat.Body2"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editTextPass2"
        style="@style/Widget.MaterialComponents.AutoCompleteTextView.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/editTextPass1"
        android:fontFamily="@font/open_sans"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="20dp"
        android:layout_weight="2"
        android:background="@drawable/edit_text_border_color_light_blue"
        android:hint="@string/confirm_password"
        android:inputType="textPassword"
        android:maxLength="10"
        android:textAppearance="@style/TextAppearance.AppCompat.Body2"
        android:textStyle="bold" />

    <Button
        android:id="@+id/buttonPassNext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextPass2"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:layout_marginRight="40dp"
        android:background="@color/colorMessageBackground"
        android:fontFamily="@font/open_sans"
        android:text="@string/next"
        android:textAllCaps="false"
        android:textColor="#ffffff"
        android:textStyle="bold" />

</RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/edit_text_border_color_radius"
        android:visibility="invisible"
        tools:visibility="invisible">

        <TextView

            android:id="@+id/id_number_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"

            android:text="Mobile Number - getIntent failed" />

        <TextView

            android:id="@+id/id_number_only_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/id_number_view"
            android:layout_centerHorizontal="true"
            android:text="Mobile Number Only View" />

        <TextView

            android:id="@+id/id_country_name_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/id_number_only_view"
            android:layout_centerHorizontal="true"
            android:text="Country Number View" />

        <TextView

            android:id="@+id/id_country_code_name_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/id_country_name_view"
            android:layout_centerHorizontal="true"
            android:text="Country Code Name View" />

        <TextView

            android:id="@+id/id_phone_code_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/id_country_code_name_view"
            android:layout_centerHorizontal="true"
            android:text="Phone Code View" />

    </RelativeLayout>

</RelativeLayout>