<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".settings.LanguageSettingsActivity">
    <RelativeLayout
        android:id="@+id/top_nav"
        android:layout_width="match_parent"
        android:layout_height="50dp">

        <ImageView
            android:id="@+id/back_settings_choose_language"
            android:layout_width="35dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="5dp"
            app:srcCompat="@drawable/common_arrow_back"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginLeft="5dp"
            android:layout_toRightOf="@id/back_settings_choose_language"
            android:text="@string/choose_language"
            android:textColor="#000000"
            android:textSize="20dp" />

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_nav"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp">

        <Button
            android:id="@+id/id_eng"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_click_effect_settings"
            android:fontFamily="@font/open_sans_condensed_bold"
            android:textStyle="bold"
            android:text="@string/english_post"
            android:textAllCaps="false"
            android:textColor="@color/black"
            />

        <Button
            android:id="@+id/id_tamil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/id_eng"
            android:layout_marginTop="12dp"
            android:textAllCaps="false"
            android:text="@string/tamil_post"
            android:background="@drawable/button_click_effect_settings"
            android:fontFamily="@font/open_sans_condensed_bold"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/id_hi"
            android:layout_below="@+id/id_tamil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAllCaps="false"
            android:text="@string/hindi_post"
            android:background="@drawable/button_click_effect_settings"
            android:fontFamily="@font/open_sans_condensed_bold"
            android:textStyle="bold"
            android:textColor="@color/black"/>

    </RelativeLayout>
</RelativeLayout>