<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_margin="5dp"
    android:layout_height="match_parent"
    android:background="@color/white"
   >


    <RelativeLayout

        android:layout_width="match_parent"
        android:layout_height="73dp">

        <ImageView
            android:id="@+id/id_user_rounded_thumbnail_notification"
            android:layout_width="47dp"
            android:layout_height="49dp"

            android:layout_centerHorizontal="false"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/placeholder2"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <ImageView
            android:id="@+id/id_buddy_rounded_thumbnail"
            android:layout_width="47dp"
            android:layout_height="49dp"

            android:layout_alignParentRight="true"
            android:layout_centerHorizontal="false"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/placeholder2"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/id_model_notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="0dp"
            android:padding="5dp"
            android:text="Id"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#000000"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/sender_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="-10dp"
            android:background="@drawable/my_message"
            android:hint="sender_name"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@color/white"
            android:textColorHint="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/sender_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="sender_name"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#000000"
            android:textColorHint="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/buddy_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="30dp"
            android:layout_marginRight="50dp"
            android:layout_marginBottom="-10dp"
            android:background="@drawable/my_message"
            android:hint="sender_name"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#FFFFFF"
            android:textColorHint="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/buddy_name_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_marginLeft="50dp"
            android:layout_marginRight="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="sender_name"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#000000"
            android:textColorHint="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/status_model_notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/sender_id"
            android:layout_marginLeft="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="status"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#3A3838"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/profile_url_model_notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/status_model_notification"
            android:layout_marginLeft="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="profile_url"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#3A3838"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />

        <TextView
            android:id="@+id/sender_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/sender_name"
            android:layout_marginLeft="50dp"
            android:layout_marginBottom="-10dp"
            android:hint="sender_id"
            android:padding="5dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="#3A3838"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="invisible"
            tools:visibility="invisible" />


    </RelativeLayout>


</FrameLayout>
