<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="40dp"
  >

    <ImageView
        android:id="@+id/id_back_arrow"
        android:layout_width="30dp"
        android:layout_height="30dp"

        android:layout_centerVertical="true"
        app:srcCompat="@drawable/select_chevron_left_black_35dp" />


    <RelativeLayout
        android:id="@+id/rrrr"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_centerVertical="true"
        android:layout_marginLeft="40dp">


        <EditText
            android:id="@+id/editTextSearch"

            android:layout_width="match_parent"
            android:layout_height="30dp"

            android:layout_marginRight="5dp"
            android:background="@drawable/search_textbox_round"
            android:hint="@string/item_12"
            android:imeOptions="actionSearch"
            android:includeFontPadding="true"
            android:inputType="text"
            android:paddingLeft="5dp"
            android:textColor="@color/company_search_light_dark"
            android:textColorHighlight="#00BCD4"
            android:textColorHint="#C46D6D6D"
            android:textColorLink="#00BCD4" />


        <ImageView
            android:id="@+id/id_action_search2"
            android:layout_width="30dp"

            android:layout_height="30dp"

            android:layout_alignParentRight="true"
            android:layout_centerInParent="true"
            android:layout_marginRight="12dp"
            app:srcCompat="@drawable/ic_search_black_24dp" />
    </RelativeLayout>



</RelativeLayout>
